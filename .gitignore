.vscode/
node_modules/
dist/
.env
/~/
*.tgz
.sessionlint/

# --- Local-only: internal planning/design docs and dev tooling (never published) ---
# Kept on this machine and in the pre-clean-backup tag; never pushed to GitHub.
/MASTER.md
/CLAUDE.md
/scripts/

# Real-history-derived fixtures stay local. Only fixtures/synthetic/ is published —
# the public test suite runs entirely on hand-authored synthetic transcripts.
/fixtures/*.jsonl
/fixtures/raw/

# All internal docs are local-only EXCEPT docs/rules/, which the CLI links to
# (findings print a docs/rules/<id>.md URL — removing it would 404 those links).
/docs/*
!/docs/rules/
