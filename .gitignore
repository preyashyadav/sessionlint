.vscode/
node_modules/
dist/
.env
/~/
*.tgz
.sessionlint/

# --- Local-only: internal planning/design docs and dev tooling (never published) ---
# Kept on this machine and in the pre-clean-backup tag; never pushed to GitHub.
/MASTER.md
/CLAUDE.md
/scripts/

# Real-history-derived fixtures stay local. Only fixtures/synthetic/ is published —
# the public test suite runs entirely on hand-authored synthetic transcripts.
/fixtures/*.jsonl
/fixtures/raw/

# Internal docs are local-only. The exceptions are the user-facing reference docs
# published with the product: docs/rules/ (the CLI's findings link to these pages),
# plus a small set of top-level reference docs listed explicitly below.
/docs/*
!/docs/rules/
!/docs/SUPPORTED_SCHEMAS.md
!/docs/json-schema.md
